{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "faigate": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "fusionAIze Gate (local gateway)",
      "options": {
        "baseURL": "http://127.0.0.1:8090/v1",
        "apiKey": "local",
        "headers": {
          "X-faigate-Client": "opencode"
        }
      },
      "models": {
        "auto": {
          "name": "fusionAIze Gate Auto-Router",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        },
        "coding-auto": {
          "name": "fusionAIze Gate Coding Auto",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        },
        "coding-fast": {
          "name": "fusionAIze Gate Coding Fast",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        },
        "coding-premium": {
          "name": "fusionAIze Gate Coding Premium",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        },
        "eco": {
          "name": "fusionAIze Gate Eco",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        },
        "premium": {
          "name": "fusionAIze Gate Premium",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        },
        "free": {
          "name": "fusionAIze Gate Free",
          "limit": {
            "context": 128000,
            "output": 8000
          }
        }
      }
    }
  }
}
