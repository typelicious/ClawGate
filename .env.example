# fusionAIze Gate – Environment Variables
# Copy to .env and fill in your keys

DEEPSEEK_API_KEY=sk-your-deepseek-key
GEMINI_API_KEY=AIza-your-gemini-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENAI_API_KEY=sk-your-openai-key

# Optional overrides
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# Default from config.yaml: /var/lib/faigate/faigate.db
# Example for local non-root runs:
# FAIGATE_DB_PATH=/home/you/.local/state/faigate/faigate.db

# Optional explicit config override for wrappers, services, and packaged installs:
# FAIGATE_CONFIG_FILE=/home/you/.config/faigate/config.yaml
