#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-logs [--follow] [--lines N]

Show recent fusionAIze Gate logs or follow them live.

Options:
  --follow     Tail logs continuously
  --lines N    Number of recent lines to print before exiting (default: 80)
EOF
}

follow="0"
lines="80"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --follow)
      follow="1"
      shift
      ;;
    --lines)
      lines="${2:-80}"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

case "$(faigate_platform)" in
  Darwin)
    mkdir -p "$(dirname "$(faigate_logs_stdout_path)")"
    touch "$(faigate_logs_stdout_path)" "$(faigate_logs_stderr_path)"
    if [ "$follow" = "1" ]; then
      tail -f "$(faigate_logs_stdout_path)" "$(faigate_logs_stderr_path)"
    else
      tail -n "$lines" "$(faigate_logs_stdout_path)" "$(faigate_logs_stderr_path)"
    fi
    ;;
  *)
    if [ "$follow" = "1" ]; then
      sudo journalctl -u faigate.service -f -o cat
    else
      sudo journalctl -u faigate.service -n "$lines" -o cat
    fi
    ;;
esac
