#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"

config_file="$(faigate_config_file)"
env_file="$(faigate_env_file)"
python_bin="$(faigate_python_bin)"
mode="text"
client_name=""
include_matrix="0"
recommended_only="0"
interactive_mode="0"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-client-integrations [--json|--text] [--client NAME] [--matrix] [--recommended] [--interactive]

Show client quickstarts and the current client-profile matrix from the active
fusionAIze Gate config.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      mode="json"
      shift
      ;;
    --text)
      mode="text"
      shift
      ;;
    --client)
      client_name="${2:-}"
      shift 2
      ;;
    --matrix)
      include_matrix="1"
      shift
      ;;
    --recommended)
      recommended_only="1"
      shift
      ;;
    --interactive)
      interactive_mode="1"
      shift
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

client_entries=()
if [[ "$interactive_mode" == "1" && -z "$client_name" && "$mode" == "text" ]]; then
  client_entries_output="$(
    FAIGATE_INTEGRATION_CONFIG="$config_file" \
    FAIGATE_INTEGRATION_ENV="$env_file" \
    "$python_bin" - <<'PY'
from faigate.onboarding import build_onboarding_report
import os

report = build_onboarding_report(
    config_path=os.environ["FAIGATE_INTEGRATION_CONFIG"],
    env_file=os.environ["FAIGATE_INTEGRATION_ENV"],
)

priority = dict(
    [
        ("opencode", 0),
        ("openclaw", 1),
        ("n8n", 2),
        ("cli", 3),
    ]
)

def sort_key(item):
    name, data = item
    recommended = 0 if data.get("recommended") else 1
    return (recommended, priority.get(name, 99), name)

for name, data in sorted(report["integrations"].items(), key=sort_key):
    readiness = "recommended" if data.get("recommended") else "available"
    print(f"{name}\t{readiness}")
PY
  )"
  while IFS= read -r entry; do
    [ -n "$entry" ] && client_entries+=("$entry")
  done <<< "$client_entries_output"
fi

FAIGATE_INTEGRATION_CONFIG="$config_file" \
FAIGATE_INTEGRATION_ENV="$env_file" \
FAIGATE_INTEGRATION_MODE="$mode" \
FAIGATE_INTEGRATION_CLIENT="$client_name" \
FAIGATE_INTEGRATION_MATRIX="$include_matrix" \
FAIGATE_INTEGRATION_RECOMMENDED="$recommended_only" \
FAIGATE_INTEGRATION_INTERACTIVE="$interactive_mode" \
"$python_bin" - <<'PY'
import json
import os

from faigate.onboarding import build_onboarding_report

report = build_onboarding_report(
    config_path=os.environ["FAIGATE_INTEGRATION_CONFIG"],
    env_file=os.environ["FAIGATE_INTEGRATION_ENV"],
)

client_name = os.environ.get("FAIGATE_INTEGRATION_CLIENT", "").strip()
include_matrix = os.environ.get("FAIGATE_INTEGRATION_MATRIX") == "1"

integrations = report["integrations"]
if client_name:
    integrations = {
        name: data for name, data in integrations.items() if name.lower() == client_name.lower()
    }
elif os.environ.get("FAIGATE_INTEGRATION_RECOMMENDED") == "1":
    integrations = {name: data for name, data in integrations.items() if data.get("recommended")}

payload = {
    "config": report["config_path"],
    "env": report["env_file"],
    "integrations": integrations,
}
if include_matrix:
    payload["client_matrix"] = report["clients"]["matrix"]

if os.environ["FAIGATE_INTEGRATION_MODE"] == "json":
    print(json.dumps(payload, indent=2, sort_keys=True))
else:
    emphasis = {
        "openclaw": "Delegated agent traffic and OpenClaw-native routing",
        "n8n": "Automation and workflow traffic",
        "opencode": "Coding-heavy editor and agent flows",
        "cli": "Direct CLI and shell-driven requests",
    }
    priority = ["opencode", "openclaw", "n8n", "cli"]
    all_integrations = report["integrations"]
    recommended_names = [
        name for name, data in all_integrations.items() if data.get("recommended")
    ]
    remaining_names = [
        name for name in all_integrations if name not in recommended_names
    ]
    best_next = ""
    for item in priority:
        if item in recommended_names:
            best_next = item
            break
    if not best_next and recommended_names:
        best_next = recommended_names[0]

    print("fusionAIze Gate Client Integrations")
    print("")
    print(f"Config: {payload['config']}")
    print(f"Env   : {payload['env']}")
    if include_matrix:
        print("")
        print("Client matrix")
        for row in payload.get("client_matrix", []):
            default_text = " [default]" if row.get("default") else ""
            print(f"- {row['name']}{default_text}: {row['source']}")
            print(f"  match: {row['matched_by']}")
            print(f"  intent: {'; '.join(row['routing_intent'])}")
    if client_name:
        print("")
        print("Client drilldown")
        for name, data in integrations.items():
            readiness = "ready" if data["recommended"] else "needs preset or custom profile"
            print(f"- {name}: {readiness}")
            print(f"  best for: {emphasis.get(name, 'Custom or framework-specific traffic')}")
            print(f"  header: {data['header']}")
            print(f"  profile: {data['profile']}")
            for snippet in data.get("snippet", []):
                print(f"  example: {snippet}")
            for note in data.get("notes", []):
                print(f"  note: {note}")
    else:
        print("")
        print("Recommended clients now")
        if best_next:
            print(f"  Best next step: {best_next}")
            if os.environ.get("FAIGATE_INTEGRATION_INTERACTIVE") == "1":
                print("  Use the drilldown selector below for one client at a time.")
            else:
                print(f"  Drill in with --client {best_next} for copyable setup details.")
        for name in recommended_names:
            data = all_integrations[name]
            print(f"- {name}")
            print(f"  best for: {emphasis.get(name, 'Custom or framework-specific traffic')}")
            print(f"  header: {data['header']}")
            print(f"  profile: {data['profile']}")
            if data.get("snippet"):
                print(f"  next: {data['snippet'][0]}")

        if remaining_names:
            print("")
            print("More available")
            print("  " + ", ".join(remaining_names))
            if os.environ.get("FAIGATE_INTEGRATION_INTERACTIVE") == "1":
                print("  Pick one below for a detailed drilldown inside Gate.")
            else:
                print("  Use --client NAME for a detailed drilldown.")
PY

if [[ "$interactive_mode" == "1" && -z "$client_name" && "$mode" == "text" && ${#client_entries[@]} -gt 0 ]]; then
  echo ""
  echo "  Open client drilldown"
  entry_index=1
  for entry in "${client_entries[@]}"; do
    client_label="${entry%%$'\t'*}"
    readiness_label="${entry#*$'\t'}"
    printf "   %2d)  %-16s %s\n" "$entry_index" "$client_label" "$readiness_label"
    entry_index=$((entry_index + 1))
  done
  echo ""
  echo "   c)  Cancel"
  echo "   q)  Quit"
  echo ""
  printf "  ▸ Selection: "
  read -r selection
  case "$selection" in
    q|Q)
      exit 0
      ;;
    c|C|"")
      exit 0
      ;;
    *)
      if [[ "$selection" =~ ^[0-9]+$ ]] && (( selection >= 1 && selection <= ${#client_entries[@]} )); then
        chosen_entry="${client_entries[$((selection - 1))]}"
        chosen_client="${chosen_entry%%$'\t'*}"
        exec "$0" --client "$chosen_client"
      fi
      echo "Invalid selection." >&2
      exit 2
      ;;
  esac
fi
