#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "${script_dir}/faigate-service-lib.sh"
source "${script_dir}/faigate-ui-lib.sh"

config_file="$(faigate_config_file)"
env_file="$(faigate_env_file)"
db_path="$(faigate_db_path)"
python_bin="$(faigate_python_bin)"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-menu

Interactive control center for fusionAIze Gate.

Env resolution:
  FAIGATE_CONFIG_FILE   config path
  FAIGATE_ENV_FILE      env path
  FAIGATE_PYTHON        python interpreter used by helper scripts
EOF
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

run_and_pause() {
  local command_rc=0
  echo ""
  "$@" || command_rc=$?
  echo ""
  if [ "$command_rc" -ne 0 ]; then
    faigate_ui_warn "Command exited with status ${command_rc}."
  fi
  faigate_ui_pause
  return 0
}

show_next_steps() {
  local title="$1"
  shift
  echo ""
  printf "  %bNext step%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "$title"
  for item in "$@"; do
    printf "    - %s\n" "$item"
  done
}

run_and_pause_with_receipt() {
  local title="$1"
  shift
  local step_count="$1"
  shift
  local -a steps=()
  local index
  for ((index = 0; index < step_count; index++)); do
    steps+=("$1")
    shift
  done

  local command_rc=0
  echo ""
  "$@" || command_rc=$?
  echo ""
  if [ "$command_rc" -ne 0 ]; then
    faigate_ui_warn "Command exited with status ${command_rc}."
  fi
  show_next_steps "$title" "${steps[@]}"
  faigate_ui_pause
  return 0
}

priority_next_step_line() {
  local action_output line label reason
  action_output="$(recommended_quick_setup_action)"
  while IFS= read -r line; do
    case "$line" in
      label=*) label="${line#label=}" ;;
      reason=*) reason="${line#reason=}" ;;
    esac
  done <<EOF
$action_output
EOF
  printf '%s\n' "Recommended next: ${label:-Validate}. ${reason:-}"
}

run_and_pause_with_priority_receipt() {
  local title="$1"
  shift
  local step_count="$1"
  shift
  local -a steps=()
  local index priority_step
  for ((index = 0; index < step_count; index++)); do
    steps+=("$1")
    shift
  done

  local command_rc=0
  echo ""
  "$@" || command_rc=$?
  echo ""
  if [ "$command_rc" -ne 0 ]; then
    faigate_ui_warn "Command exited with status ${command_rc}."
  fi
  priority_step="$(priority_next_step_line)"
  show_next_steps "$title" \
    "$priority_step" \
    "Quick Setup shortcut: return here and press r to open the current recommended path directly." \
    "${steps[@]}"
  faigate_ui_pause
  return 0
}

guided_route_additions_counts() {
  bash "${script_dir}/faigate-provider-setup" --recommended --json | "$python_bin" - <<'PY'
import json
import sys

payload = json.loads(sys.stdin.read() or "{}")
print(
    len(payload.get("actionable_additions") or []),
    len(payload.get("auto_apply_additions") or []),
    len(payload.get("manual_additions") or []),
)
PY
}

offer_guided_route_additions_now() {
  local context_label="$1"
  local counts total_count auto_count manual_count
  counts="$(guided_route_additions_counts)"
  read -r total_count auto_count manual_count <<EOF
$counts
EOF

  if [ "${total_count:-0}" -le 0 ]; then
    return 0
  fi

  echo ""
  faigate_ui_tip "${context_label} surfaced ${total_count} recommended route addition(s)."
  if [ "${auto_count:-0}" -gt 0 ]; then
    faigate_ui_info "${auto_count} route addition(s) are ready for one-pass apply right now."
  fi
  if [ "${manual_count:-0}" -gt 0 ]; then
    faigate_ui_info "${manual_count} route addition(s) still need env values if you want to add them now."
  fi
  printf "  Open Guided Route Additions now? [y/N]: "
  read -r guided_choice
  if [[ "${guided_choice:-N}" =~ ^[Yy]$ ]]; then
    bash "${script_dir}/faigate-provider-setup" --recommended --interactive
  fi
}

dynamic_operator_followups() {
  local snapshot_output line route_gaps refresh_now review_soon top_refresh_provider top_add_provider
  local catalog_errors catalog_due catalog_changes top_catalog_provider
  local catalog_fix_now catalog_review_now top_catalog_action
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      route_gaps=*) route_gaps="${line#route_gaps=}" ;;
      refresh_now=*) refresh_now="${line#refresh_now=}" ;;
      review_soon=*) review_soon="${line#review_soon=}" ;;
      catalog_errors=*) catalog_errors="${line#catalog_errors=}" ;;
      catalog_due=*) catalog_due="${line#catalog_due=}" ;;
      catalog_changes=*) catalog_changes="${line#catalog_changes=}" ;;
      catalog_fix_now=*) catalog_fix_now="${line#catalog_fix_now=}" ;;
      catalog_review_now=*) catalog_review_now="${line#catalog_review_now=}" ;;
      top_refresh_provider=*) top_refresh_provider="${line#top_refresh_provider=}" ;;
      top_add_provider=*) top_add_provider="${line#top_add_provider=}" ;;
      top_catalog_provider=*) top_catalog_provider="${line#top_catalog_provider=}" ;;
      top_catalog_action=*) top_catalog_action="${line#top_catalog_action=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  if [ "${route_gaps:-0}" -gt 0 ]; then
    printf '%s\n' "Open Provider Setup -> Guided Route Additions next to close ${route_gaps} recommended lane gap(s)${top_add_provider:+, starting with ${top_add_provider}}."
  fi
  if [ "${refresh_now:-0}" -gt 0 ]; then
    printf '%s\n' "Review stale route assumptions before heavier traffic leans on them${top_refresh_provider:+, starting with ${top_refresh_provider}}."
  elif [ "${review_soon:-0}" -gt 0 ]; then
    printf '%s\n' "Review aging route assumptions soon${top_refresh_provider:+, starting with ${top_refresh_provider}}."
  fi
  if [ "${catalog_fix_now:-0}" -gt 0 ]; then
    printf '%s\n' "Refresh provider source catalog now to repair high-priority source drift or lookup failures${top_catalog_provider:+, starting with ${top_catalog_provider}}${top_catalog_action:+ (${top_catalog_action})}."
  elif [ "${catalog_review_now:-0}" -gt 0 ]; then
    printf '%s\n' "Review provider source catalog freshness before leaning on older pricing or model assumptions${top_catalog_provider:+, starting with ${top_catalog_provider}}."
  fi
}

recommended_quick_setup_action() {
  local snapshot_output line health_state providers_count providers_ready providers_missing_keys
  local route_gaps refresh_now review_soon next_client top_refresh_provider top_refresh_action top_add_provider
  local catalog_errors catalog_due catalog_changes top_catalog_provider
  local catalog_fix_now catalog_review_now top_catalog_action
  local key label reason choice
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      health=*) health_state="${line#health=}" ;;
      providers=*) providers_count="${line#providers=}" ;;
      providers_ready=*) providers_ready="${line#providers_ready=}" ;;
      providers_missing_keys=*) providers_missing_keys="${line#providers_missing_keys=}" ;;
      route_gaps=*) route_gaps="${line#route_gaps=}" ;;
      refresh_now=*) refresh_now="${line#refresh_now=}" ;;
      review_soon=*) review_soon="${line#review_soon=}" ;;
      catalog_errors=*) catalog_errors="${line#catalog_errors=}" ;;
      catalog_due=*) catalog_due="${line#catalog_due=}" ;;
      catalog_changes=*) catalog_changes="${line#catalog_changes=}" ;;
      catalog_fix_now=*) catalog_fix_now="${line#catalog_fix_now=}" ;;
      catalog_review_now=*) catalog_review_now="${line#catalog_review_now=}" ;;
      next_client=*) next_client="${line#next_client=}" ;;
      top_refresh_provider=*) top_refresh_provider="${line#top_refresh_provider=}" ;;
      top_refresh_action=*) top_refresh_action="${line#top_refresh_action=}" ;;
      top_add_provider=*) top_add_provider="${line#top_add_provider=}" ;;
      top_catalog_provider=*) top_catalog_provider="${line#top_catalog_provider=}" ;;
      top_catalog_action=*) top_catalog_action="${line#top_catalog_action=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  if [ "${providers_count:-0}" -eq 0 ]; then
    key="provider-setup"
    choice="1"
    label="Provider Setup"
    reason="No provider sources are configured yet. Add at least one live source before tuning routing or client defaults."
  elif [ "${providers_missing_keys:-0}" -gt 0 ] || [ "${providers_ready:-0}" -eq 0 ]; then
    key="api-keys"
    choice="2"
    label="API Keys"
    reason="Configured providers are still missing credentials. Fill those in before spending time on routing and client posture."
  elif [ "${health_state:-unreachable}" != "healthy" ]; then
    key="restart-verify"
    choice="6"
    label="Restart + Verify"
    reason="The gateway is not healthy yet. Bring the current config live again before leaning on route coverage or client flows."
  elif [ "${route_gaps:-0}" -gt 0 ]; then
    key="guided-routes"
    choice="1"
    label="Provider Setup -> Guided Route Additions"
    reason="Recommended lane mirrors are still missing. Close those route gaps next${top_add_provider:+, starting with ${top_add_provider}}."
  elif [ "${catalog_fix_now:-0}" -gt 0 ]; then
    key="provider-catalog"
    choice="10"
    label="Provider Catalog"
    reason="Provider source evidence needs intervention before we lean on it. Revalidate source URLs, parsers, or overdue refreshes next${top_catalog_provider:+, starting with ${top_catalog_provider}}${top_catalog_action:+ (${top_catalog_action})}."
  elif [ "${catalog_review_now:-0}" -gt 0 ]; then
    key="provider-catalog"
    choice="10"
    label="Provider Catalog"
    reason="Provider source snapshots need review before we trust older route economics${top_catalog_provider:+, starting with ${top_catalog_provider}}."
  elif [ "${refresh_now:-0}" -gt 0 ]; then
    key="provider-probe"
    choice="3"
    label="Provider Probe"
    reason="Current benchmark and cost assumptions need review before heavier traffic leans on them${top_refresh_provider:+, starting with ${top_refresh_provider} (${top_refresh_action:-review})}."
  elif [ "${review_soon:-0}" -gt 0 ]; then
    key="provider-probe"
    choice="3"
    label="Provider Probe"
    reason="The gateway is live, but some route assumptions are aging and should be reviewed soon${top_refresh_provider:+, starting with ${top_refresh_provider}}."
  elif [ -n "${next_client:-}" ] && [ "${next_client}" != "none" ]; then
    key="client-quickstarts"
    choice="8"
    label="Client Quickstarts"
    reason="The gateway looks ready. Wire in ${next_client} next so real traffic starts using the current routing posture."
  else
    key="validate"
    choice="5"
    label="Validate"
    reason="The baseline looks good. Run the operator checks once more before treating the current setup as ready."
  fi

  printf 'key=%s\n' "$key"
  printf 'choice=%s\n' "$choice"
  printf 'label=%s\n' "$label"
  printf 'reason=%s\n' "$reason"
}

render_priority_next_step() {
  local action_output line label reason
  action_output="$(recommended_quick_setup_action)"
  while IFS= read -r line; do
    case "$line" in
      label=*) label="${line#label=}" ;;
      reason=*) reason="${line#reason=}" ;;
    esac
  done <<EOF
$action_output
EOF

  echo ""
  printf "  %bPriority next%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Path" "${label:-n/a}"
  printf "  %-18s %s\n" "Why" "${reason:-No dominant next action right now.}"
}

quick_setup_recommended_choice() {
  local action_output line choice
  action_output="$(recommended_quick_setup_action)"
  while IFS= read -r line; do
    case "$line" in
      choice=*) choice="${line#choice=}" ;;
    esac
  done <<EOF
$action_output
EOF
  printf '%s\n' "${choice:-}"
}

quick_setup_option_text() {
  local option_number="$1"
  local label="$2"
  local recommended_choice
  recommended_choice="$(quick_setup_recommended_choice)"
  if [ "$recommended_choice" = "$option_number" ]; then
    printf '%s\n' "${label} (Recommended)"
  else
    printf '%s\n' "$label"
  fi
}

run_recommended_quick_setup_action() {
  local action_output line key
  action_output="$(recommended_quick_setup_action)"
  while IFS= read -r line; do
    case "$line" in
      key=*) key="${line#key=}" ;;
    esac
  done <<EOF
$action_output
EOF

  case "${key:-}" in
    provider-setup) run_provider_setup_with_handoff ;;
    guided-routes) run_and_pause bash "${script_dir}/faigate-provider-setup" --recommended --interactive ;;
    provider-catalog) run_and_pause bash "${script_dir}/faigate-provider-catalog" --refresh ;;
    api-keys) run_and_pause bash "${script_dir}/faigate-api-keys" ;;
    provider-probe) run_and_pause bash "${script_dir}/faigate-provider-probe" ;;
    validate) run_and_pause bash "${script_dir}/faigate-doctor" ;;
    restart-verify) run_and_pause bash "${script_dir}/faigate-restart" ;;
    client-scenarios) run_and_pause bash "${script_dir}/faigate-client-scenarios" ;;
    client-quickstarts) run_and_pause bash "${script_dir}/faigate-client-integrations" --recommended ;;
    current-config) run_and_pause bash "${script_dir}/faigate-config-overview" ;;
  esac
}

offer_priority_followup_now() {
  local action_output line key label
  action_output="$(recommended_quick_setup_action)"
  while IFS= read -r line; do
    case "$line" in
      key=*) key="${line#key=}" ;;
      label=*) label="${line#label=}" ;;
    esac
  done <<EOF
$action_output
EOF

  case "${key:-}" in
    ""|none) return 0 ;;
  esac

  printf "  Open the recommended next step now (%s)? [y/N]: " "${label:-next step}"
  read -r followup_choice
  if [[ "${followup_choice:-N}" =~ ^[Yy]$ ]]; then
    run_recommended_quick_setup_action
  fi
}

run_provider_setup_with_handoff() {
  local command_rc=0
  echo ""
  bash "${script_dir}/faigate-provider-setup" || command_rc=$?
  echo ""
  if [ "$command_rc" -ne 0 ]; then
    faigate_ui_warn "Command exited with status ${command_rc}."
  else
    offer_guided_route_additions_now "Provider Setup"
  fi
  show_next_steps "Provider sources updated." \
    "Use API Keys next when one or more selected providers still need credentials." \
    "Run Full Config Wizard after provider setup to refresh routing defaults around the new sources." \
    "Run Validate once config and env both look close."
  faigate_ui_pause
  return 0
}

menu_snapshot() {
  local menu_db_explicit="0"
  if [ -n "${FAIGATE_DB_PATH:-}" ]; then
    menu_db_explicit="1"
  fi
  FAIGATE_MENU_CONFIG="$config_file" \
  FAIGATE_MENU_ENV="$env_file" \
  FAIGATE_MENU_DB="$db_path" \
  FAIGATE_MENU_DB_EXPLICIT="$menu_db_explicit" \
  "$python_bin" - <<'PY'
from pathlib import Path
import os
import re

import yaml
from faigate.provider_catalog import build_provider_refresh_guidance
from faigate.provider_catalog_refresh import build_catalog_alert_summary, build_catalog_summary
from faigate.provider_catalog_store import ProviderCatalogStore
from faigate.wizard import build_route_add_setup_plan

config_path = Path(os.environ["FAIGATE_MENU_CONFIG"])
env_path = Path(os.environ["FAIGATE_MENU_ENV"])
raw = {}
if config_path.exists():
    with config_path.open(encoding="utf-8") as handle:
        raw = yaml.safe_load(handle) or {}

env_values = {}
if env_path.exists():
    for line in env_path.read_text(encoding="utf-8").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, value = stripped.split("=", 1)
        env_values[key.strip()] = value.strip().strip('"').strip("'")

providers = raw.get("providers") or {}
fallback_chain = raw.get("fallback_chain") or []
routing = raw.get("routing_modes") or {}
client_profiles = raw.get("client_profiles") or {}
profiles = (client_profiles.get("profiles") or {}) if isinstance(client_profiles, dict) else {}
presets = (client_profiles.get("presets") or []) if isinstance(client_profiles, dict) else []
providers_ready = 0
providers_missing_keys = 0

for payload in providers.values():
    if not isinstance(payload, dict):
        continue
    api_key = payload.get("api_key")
    if isinstance(api_key, str):
        match = re.fullmatch(r"\$\{([^}:]+)(?::-[^}]*)?\}", api_key.strip())
        if match:
            if env_values.get(match.group(1), ""):
                providers_ready += 1
            else:
                providers_missing_keys += 1
            continue
    providers_ready += 1

default_profile = (
    client_profiles.get("default", "generic") if isinstance(client_profiles, dict) else "generic"
)
next_client = ""
priority = ["opencode", "openclaw", "n8n", "cli"]
if default_profile in priority:
    next_client = default_profile
else:
    available_client_targets = set(priority) & (set(profiles) | set(presets))
    for item in priority:
        if item in available_client_targets:
            next_client = item
            break

preset_summary = "none yet"
if len(presets) == 1:
    preset_summary = "1 active"
elif len(presets) > 1:
    preset_summary = f"{len(presets)} active"

provider_names = [
    name for name, payload in providers.items() if isinstance(payload, dict) and str(name).strip()
]
provider_source_refresh = raw.get("provider_source_refresh") or {}
tracked_catalog_providers = provider_source_refresh.get("providers") or ["blackbox", "kilo", "openai"]
route_plan = build_route_add_setup_plan(
    config_path=config_path,
    env_file=env_path,
    source_providers=provider_names,
)
refresh_guidance = build_provider_refresh_guidance(
    provider_names,
    freshness_overrides={
        str(name): {
            "freshness_status": str((payload.get("lane") or {}).get("freshness_status") or ""),
            "review_age_days": (payload.get("lane") or {}).get("review_age_days"),
            "freshness_hint": str((payload.get("lane") or {}).get("freshness_hint") or ""),
        }
        for name, payload in providers.items()
        if isinstance(payload, dict)
    },
)
top_refresh = refresh_guidance[0] if refresh_guidance else {}
top_add = (
    (route_plan.get("actionable_additions") or [{}])[0]
    if route_plan.get("actionable_additions")
    else {}
)
catalog_summary = {}
metrics_cfg = raw.get("metrics") or {}
configured_db_path = str(metrics_cfg.get("db_path") or "").strip() if isinstance(metrics_cfg, dict) else ""
if configured_db_path:
    db_path = Path(configured_db_path)
elif os.environ.get("FAIGATE_MENU_DB_EXPLICIT") == "1":
    db_path = Path(os.environ["FAIGATE_MENU_DB"])
else:
    db_path = Path("")
if str(db_path):
    try:
        store = ProviderCatalogStore(str(db_path))
        store.init()
        try:
            catalog_summary = build_catalog_summary(
                store,
                provider_ids=list(tracked_catalog_providers),
            )
        finally:
            store.close()
    except Exception:
        catalog_summary = {}

catalog_alert_summary = dict(
    catalog_summary.get("alert_summary")
    or build_catalog_alert_summary(list(catalog_summary.get("alerts") or []))
)
top_catalog_alert = (
    (catalog_summary.get("alerts") or [{}])[0]
    if catalog_summary.get("alerts")
    else {}
)

print(f"providers={len(providers)}")
print(f"providers_ready={providers_ready}")
print(f"providers_missing_keys={providers_missing_keys}")
print(f"fallbacks={len(fallback_chain)}")
print(f"default_mode={routing.get('default', 'auto')}")
print(f"default_profile={default_profile}")
print(f"profiles={len(profiles)}")
print(f"presets={len(presets)}")
print(f"preset_summary={preset_summary}")
print(f"next_client={next_client or 'none'}")
print(f"route_gaps={len(route_plan.get('actionable_additions') or [])}")
print(f"route_gaps_ready={len(route_plan.get('auto_apply_additions') or [])}")
print(f"route_gaps_manual={len(route_plan.get('manual_additions') or [])}")
print(
    "refresh_now="
    + str(sum(1 for item in refresh_guidance if str(item.get("action") or "") == "refresh-now"))
)
print(
    "review_soon="
    + str(sum(1 for item in refresh_guidance if str(item.get("action") or "") == "review-soon"))
)
print(f"catalog_tracked={int(catalog_summary.get('tracked_sources') or 0)}")
print(f"catalog_errors={int(catalog_summary.get('error_sources') or 0)}")
print(f"catalog_due={int(catalog_summary.get('due_sources') or 0)}")
print(f"catalog_changes={int(catalog_summary.get('recent_changes') or 0)}")
print(f"catalog_alert_status={str(catalog_alert_summary.get('status') or 'clear')}")
print(f"catalog_fix_now={int(catalog_alert_summary.get('fix_now') or 0)}")
print(f"catalog_review_now={int(catalog_alert_summary.get('review_now') or 0)}")
print(f"top_refresh_provider={top_refresh.get('provider', '')}")
print(f"top_refresh_action={top_refresh.get('action_label', '')}")
print(f"top_add_provider={top_add.get('setup_provider_name') or top_add.get('provider_name') or ''}")
print(f"top_catalog_provider={str(top_catalog_alert.get('provider_id') or '')}")
print(f"top_catalog_action={str(top_catalog_alert.get('action') or '')}")
PY
}

collect_runtime_snapshot() {
  local state health_state bind snapshot_output line providers_count providers_ready providers_missing_keys
  local fallback_count default_mode default_profile profile_count preset_count
  local preset_summary next_client route_gaps route_gaps_ready route_gaps_manual
  local refresh_now review_soon top_refresh_provider top_refresh_action top_add_provider
  local catalog_tracked catalog_errors catalog_due catalog_changes top_catalog_provider
  local catalog_alert_status catalog_fix_now catalog_review_now top_catalog_action
  state="$(faigate_service_state)"
  if faigate_is_healthy; then
    health_state="healthy"
  else
    health_state="unreachable"
  fi
  bind="$(faigate_host):$(faigate_port)"
  snapshot_output="$(menu_snapshot)"
  providers_count="0"
  providers_ready="0"
  providers_missing_keys="0"
  fallback_count="0"
  default_mode="auto"
  default_profile="generic"
  profile_count="0"
  preset_count="0"
  while IFS= read -r line; do
    case "$line" in
      providers=*) providers_count="${line#providers=}" ;;
      providers_ready=*) providers_ready="${line#providers_ready=}" ;;
      providers_missing_keys=*) providers_missing_keys="${line#providers_missing_keys=}" ;;
      fallbacks=*) fallback_count="${line#fallbacks=}" ;;
      default_mode=*) default_mode="${line#default_mode=}" ;;
      default_profile=*) default_profile="${line#default_profile=}" ;;
      profiles=*) profile_count="${line#profiles=}" ;;
      presets=*) preset_count="${line#presets=}" ;;
      preset_summary=*) preset_summary="${line#preset_summary=}" ;;
      next_client=*) next_client="${line#next_client=}" ;;
      route_gaps=*) route_gaps="${line#route_gaps=}" ;;
      route_gaps_ready=*) route_gaps_ready="${line#route_gaps_ready=}" ;;
      route_gaps_manual=*) route_gaps_manual="${line#route_gaps_manual=}" ;;
      refresh_now=*) refresh_now="${line#refresh_now=}" ;;
      review_soon=*) review_soon="${line#review_soon=}" ;;
      catalog_tracked=*) catalog_tracked="${line#catalog_tracked=}" ;;
      catalog_errors=*) catalog_errors="${line#catalog_errors=}" ;;
      catalog_due=*) catalog_due="${line#catalog_due=}" ;;
      catalog_changes=*) catalog_changes="${line#catalog_changes=}" ;;
      catalog_alert_status=*) catalog_alert_status="${line#catalog_alert_status=}" ;;
      catalog_fix_now=*) catalog_fix_now="${line#catalog_fix_now=}" ;;
      catalog_review_now=*) catalog_review_now="${line#catalog_review_now=}" ;;
      top_refresh_provider=*) top_refresh_provider="${line#top_refresh_provider=}" ;;
      top_refresh_action=*) top_refresh_action="${line#top_refresh_action=}" ;;
      top_add_provider=*) top_add_provider="${line#top_add_provider=}" ;;
      top_catalog_provider=*) top_catalog_provider="${line#top_catalog_provider=}" ;;
      top_catalog_action=*) top_catalog_action="${line#top_catalog_action=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  printf 'state=%s\n' "$state"
  printf 'health=%s\n' "$health_state"
  printf 'bind=%s\n' "$bind"
  printf 'providers=%s\n' "$providers_count"
  printf 'providers_ready=%s\n' "$providers_ready"
  printf 'providers_missing_keys=%s\n' "$providers_missing_keys"
  printf 'fallbacks=%s\n' "$fallback_count"
  printf 'default_mode=%s\n' "$default_mode"
  printf 'default_profile=%s\n' "$default_profile"
  printf 'profiles=%s\n' "$profile_count"
  printf 'presets=%s\n' "$preset_count"
  printf 'preset_summary=%s\n' "${preset_summary:-none yet}"
  printf 'next_client=%s\n' "${next_client:-none}"
  printf 'route_gaps=%s\n' "${route_gaps:-0}"
  printf 'route_gaps_ready=%s\n' "${route_gaps_ready:-0}"
  printf 'route_gaps_manual=%s\n' "${route_gaps_manual:-0}"
  printf 'refresh_now=%s\n' "${refresh_now:-0}"
  printf 'review_soon=%s\n' "${review_soon:-0}"
  printf 'catalog_tracked=%s\n' "${catalog_tracked:-0}"
  printf 'catalog_errors=%s\n' "${catalog_errors:-0}"
  printf 'catalog_due=%s\n' "${catalog_due:-0}"
  printf 'catalog_changes=%s\n' "${catalog_changes:-0}"
  printf 'catalog_alert_status=%s\n' "${catalog_alert_status:-clear}"
  printf 'catalog_fix_now=%s\n' "${catalog_fix_now:-0}"
  printf 'catalog_review_now=%s\n' "${catalog_review_now:-0}"
  printf 'top_refresh_provider=%s\n' "${top_refresh_provider:-}"
  printf 'top_refresh_action=%s\n' "${top_refresh_action:-}"
  printf 'top_add_provider=%s\n' "${top_add_provider:-}"
  printf 'top_catalog_provider=%s\n' "${top_catalog_provider:-}"
  printf 'top_catalog_action=%s\n' "${top_catalog_action:-}"
}

render_summary_cards() {
  local snapshot_output line state health_state bind providers_count providers_ready providers_missing_keys
  local fallback_count default_mode default_profile profile_count preset_count preset_summary next_client
  local route_gaps refresh_now review_soon catalog_tracked catalog_errors catalog_due catalog_changes
  local catalog_alert_status catalog_fix_now catalog_review_now top_catalog_provider top_catalog_action
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      state=*) state="${line#state=}" ;;
      health=*) health_state="${line#health=}" ;;
      bind=*) bind="${line#bind=}" ;;
      providers=*) providers_count="${line#providers=}" ;;
      providers_ready=*) providers_ready="${line#providers_ready=}" ;;
      providers_missing_keys=*) providers_missing_keys="${line#providers_missing_keys=}" ;;
      fallbacks=*) fallback_count="${line#fallbacks=}" ;;
      default_mode=*) default_mode="${line#default_mode=}" ;;
      default_profile=*) default_profile="${line#default_profile=}" ;;
      profiles=*) profile_count="${line#profiles=}" ;;
      presets=*) preset_count="${line#presets=}" ;;
      preset_summary=*) preset_summary="${line#preset_summary=}" ;;
      next_client=*) next_client="${line#next_client=}" ;;
      route_gaps=*) route_gaps="${line#route_gaps=}" ;;
      refresh_now=*) refresh_now="${line#refresh_now=}" ;;
      review_soon=*) review_soon="${line#review_soon=}" ;;
      catalog_tracked=*) catalog_tracked="${line#catalog_tracked=}" ;;
      catalog_errors=*) catalog_errors="${line#catalog_errors=}" ;;
      catalog_due=*) catalog_due="${line#catalog_due=}" ;;
      catalog_changes=*) catalog_changes="${line#catalog_changes=}" ;;
      catalog_alert_status=*) catalog_alert_status="${line#catalog_alert_status=}" ;;
      catalog_fix_now=*) catalog_fix_now="${line#catalog_fix_now=}" ;;
      catalog_review_now=*) catalog_review_now="${line#catalog_review_now=}" ;;
      top_catalog_provider=*) top_catalog_provider="${line#top_catalog_provider=}" ;;
      top_catalog_action=*) top_catalog_action="${line#top_catalog_action=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF

  printf "  %bGateway%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Service" "$state"
  printf "  %-18s %s\n" "Health" "$health_state"
  printf "  %-18s %s\n" "Bind" "$bind"
  echo ""
  printf "  %bConfig%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Default mode" "$default_mode"
  printf "  %-18s %s\n" "Config" "$config_file"
  printf "  %-18s %s\n" "Env" "$env_file"
  echo ""
  printf "  %bProviders%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Configured" "$providers_count"
  printf "  %-18s %s\n" "Ready" "$providers_ready"
  printf "  %-18s %s\n" "Missing keys" "$providers_missing_keys"
  printf "  %-18s %s\n" "Fallbacks" "$fallback_count"
  if [ "${route_gaps:-0}" -gt 0 ]; then
    printf "  %-18s %s\n" "Route gaps" "$route_gaps"
  fi
  if [ "${refresh_now:-0}" -gt 0 ]; then
    printf "  %-18s %s\n" "Refresh now" "$refresh_now"
  elif [ "${review_soon:-0}" -gt 0 ]; then
    printf "  %-18s %s\n" "Review soon" "$review_soon"
  fi
  if [ "${catalog_tracked:-0}" -gt 0 ]; then
    printf "  %-18s %s\n" "Catalog tracked" "$catalog_tracked"
    printf "  %-18s %s\n" "Catalog status" "${catalog_alert_status:-clear}"
    printf "  %-18s %s\n" "Catalog fix now" "${catalog_fix_now:-0}"
    printf "  %-18s %s\n" "Catalog review" "${catalog_review_now:-0}"
    printf "  %-18s %s\n" "Catalog errors" "${catalog_errors:-0}"
    printf "  %-18s %s\n" "Catalog due" "${catalog_due:-0}"
    if [ "${catalog_changes:-0}" -gt 0 ]; then
      printf "  %-18s %s\n" "Catalog changes" "${catalog_changes:-0}"
    fi
    if [ -n "${top_catalog_provider:-}" ]; then
      printf "  %-18s %s\n" "Catalog focus" "${top_catalog_provider}${top_catalog_action:+ (${top_catalog_action})}"
    fi
  fi
  echo ""
  printf "  %bClients%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
  printf "  %-18s %s\n" "Default profile" "$default_profile"
  printf "  %-18s %s\n" "Profiles" "$profile_count"
  printf "  %-18s %s\n" "Preset matches" "${preset_summary:-none yet}"
  if [ -n "${next_client:-}" ] && [ "${next_client}" != "none" ]; then
    printf "  %-18s %s\n" "Best next step" "$next_client"
  fi
  printf "\n"
}

best_next_client() {
  local snapshot_output line next_client
  snapshot_output="$(collect_runtime_snapshot)"
  while IFS= read -r line; do
    case "$line" in
      next_client=*) next_client="${line#next_client=}" ;;
    esac
  done <<EOF
$snapshot_output
EOF
  if [ -n "${next_client:-}" ] && [ "$next_client" != "none" ]; then
    printf "%s\n" "$next_client"
  fi
}

render_quick_setup_guidance() {
  local action_output line reason
  action_output="$(recommended_quick_setup_action)"
  while IFS= read -r line; do
    case "$line" in
      reason=*) reason="${line#reason=}" ;;
    esac
  done <<EOF
$action_output
EOF

  faigate_ui_tip "${reason:-Use Quick Setup to work through the current highest-priority next step.}"
}

show_status_overview() {
  local version host port log_level health_state
  version="$("$python_bin" -m faigate --version 2>/dev/null || echo "faigate unknown")"
  host="$(faigate_host)"
  port="$(faigate_port)"
  log_level="$(faigate_log_level)"
  if curl -fsS -m 2 "$(faigate_health_url)" >/dev/null 2>&1; then
    health_state="healthy"
  else
    health_state="unreachable"
  fi

  faigate_ui_header "fusionAIze Gate Status" "Standalone control center"
  printf "  %-18s %s\n" "Version" "$version"
  printf "  %-18s %s\n" "Config" "$config_file"
  printf "  %-18s %s\n" "Env" "$env_file"
  printf "  %-18s %s\n" "Database" "$db_path"
  printf "  %-18s %s\n" "Bind" "${host}:${port}"
  printf "  %-18s %s\n" "Log level" "$log_level"
  printf "  %-18s %s\n" "Health" "$health_state"
}

show_models() {
  local models_url payload
  models_url="$(faigate_models_url)"
  if ! payload="$(curl -fsS -m 2 "$models_url")"; then
    faigate_ui_error "Model list is not reachable at ${models_url}."
    return 1
  fi

  FAIGATE_MODELS_PAYLOAD="$payload" "$python_bin" - <<'PY'
import json
import os

data = json.loads(os.environ["FAIGATE_MODELS_PAYLOAD"])
models = [item.get("id", "") for item in data.get("data", []) if item.get("id")]

print(f"Exposed models: {len(models)}")
for idx, model in enumerate(models, start=1):
    marker = " (recommended default)" if model == "auto" else ""
    print(f"{idx:>2}. {model}{marker}")
PY
}

run_config_wizard() {
  local purpose_in purpose client selection apply_mode backup_suffix
  local -a cmd_args

  faigate_ui_header "fusionAIze Gate Config Wizard" "Providers, routing modes, client profiles"
  printf "  %bPurpose%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(1=general  2=coding  3=quality  4=free)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ [general]: "
  read -r purpose_in
  case "${purpose_in:-1}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
    1|general|"") purpose="general" ;;
    2|coding) purpose="coding" ;;
    3|quality) purpose="quality" ;;
    4|free) purpose="free" ;;
    *) purpose="general" ;;
  esac

  echo ""
  printf "  %bClient profile%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(generic | openclaw | n8n | cli | opencode)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ [generic]: "
  read -r client
  case "${client:-generic}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
    ""|generic|openclaw|n8n|cli|opencode) client="${client:-generic}" ;;
    *) client="generic" ;;
  esac

  echo ""
  faigate_ui_info "Fetching provider candidates for purpose=${purpose} client=${client}..."
  echo ""
  FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
    bash "${script_dir}/faigate-config-wizard" \
      --env-file "$env_file" \
      --purpose "$purpose" \
      --client "$client" \
      --current-config "$config_file" \
      --text-candidates \
      --list-candidates || true

  echo ""
  printf "  %bSelect providers%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(comma-separated IDs, 'all', Enter = recommendations)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ Selection: "
  read -r selection
  case "$selection" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  echo ""
  printf "  %bApply mode%b\n" "$FAIGATE_UI_BOLD"
  printf "    1)  Dry-run only    Preview changes, no writes\n"
  printf "    2)  Write config    Update config.yaml (backup created automatically)\n"
  printf "    c)  Cancel\n"
  printf "    q)  Quit\n"
  printf "  ▸ [1]: "
  read -r apply_mode
  case "${apply_mode:-1}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  cmd_args=(--env-file "$env_file" --purpose "$purpose" --client "$client")
  if [ -f "$config_file" ]; then
    cmd_args+=(--current-config "$config_file" --merge-existing)
    if [ "${apply_mode:-1}" = "2" ]; then
      cmd_args+=(--apply recommended_add,recommended_replace,recommended_mode_changes)
    fi
  fi
  if [ -n "$selection" ] && [ "$selection" != "all" ]; then
    cmd_args+=(--select "$selection")
  fi

  if [ "${apply_mode:-1}" = "2" ]; then
    backup_suffix=".before-wizard-$(date +%Y%m%d%H%M%S)"
    cmd_args+=(--write "$config_file" --write-backup --backup-suffix "$backup_suffix")
    local command_rc=0
    local action_output line priority_label
    echo ""
    env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}" || command_rc=$?
    echo ""
    if [ "$command_rc" -ne 0 ]; then
      faigate_ui_warn "Command exited with status ${command_rc}."
    else
      offer_guided_route_additions_now "Full Config Wizard"
    fi
    local -a dynamic_steps=()
    mapfile -t dynamic_steps < <(dynamic_operator_followups)
    action_output="$(recommended_quick_setup_action)"
    while IFS= read -r line; do
      case "$line" in
        label=*) priority_label="${line#label=}" ;;
      esac
    done <<EOF
$action_output
EOF
    show_next_steps "Wizard wrote the config." \
      "Recommended next: ${priority_label:-Validate}." \
      "Restart + Verify to load the new config." \
      "Run Validate if you changed providers or routing defaults." \
      "Open Clients when you want the first consumer wired in." \
      "${dynamic_steps[@]}"
    faigate_ui_pause
    offer_priority_followup_now
  else
    cmd_args+=(--dry-run-summary)
    run_and_pause_with_receipt "Dry-run completed." 3 \
      "Write config when the provider set and mode changes look right." \
      "Update API Keys first if the suggested providers are not ready yet." \
      "Use Validate after writing changes to catch missing pieces early." \
      env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}"
  fi
}

run_client_wizard() {
  local client="$1"
  local purpose="${2:-general}"
  local selection apply_mode backup_suffix
  local -a cmd_args

  faigate_ui_header "fusionAIze Gate Client Wizard" "Scoped to client profile: ${client}"
  faigate_ui_info "Fetching provider candidates for purpose=${purpose} client=${client}..."
  echo ""
  FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
    bash "${script_dir}/faigate-config-wizard" \
      --env-file "$env_file" \
      --purpose "$purpose" \
      --client "$client" \
      --current-config "$config_file" \
      --text-candidates \
      --list-candidates || true

  echo ""
  printf "  %bSelect providers%b  %s\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET" "(comma-separated IDs, 'all', Enter = recommendations)"
  printf "  q) Quit\n"
  printf "  c) Cancel\n"
  printf "  ▸ Selection: "
  read -r selection
  case "$selection" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  echo ""
  printf "  %bApply mode%b\n" "$FAIGATE_UI_BOLD"
  printf "    1)  Dry-run only    Preview changes, no writes\n"
  printf "    2)  Write config    Update config.yaml (backup created automatically)\n"
  printf "    c)  Cancel\n"
  printf "    q)  Quit\n"
  printf "  ▸ [1]: "
  read -r apply_mode
  case "${apply_mode:-1}" in
    q|Q) exit 0 ;;
    c|C) return 0 ;;
  esac

  cmd_args=(
    --env-file "$env_file"
    --purpose "$purpose"
    --client "$client"
    --current-config "$config_file"
    --merge-existing
  )
  if [ "${apply_mode:-1}" = "2" ]; then
    cmd_args+=(--apply recommended_add,recommended_replace,recommended_mode_changes)
    cmd_args+=(--select-profiles "$client")
  fi
  if [ -n "$selection" ] && [ "$selection" != "all" ]; then
    cmd_args+=(--select "$selection")
  fi

  if [ "${apply_mode:-1}" = "2" ]; then
    backup_suffix=".client-${client}-$(date +%Y%m%d%H%M%S)"
    cmd_args+=(--write "$config_file" --write-backup --backup-suffix "$backup_suffix")
    local command_rc=0
    local action_output line priority_label
    echo ""
    env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}" || command_rc=$?
    echo ""
    if [ "$command_rc" -ne 0 ]; then
      faigate_ui_warn "Command exited with status ${command_rc}."
    else
      offer_guided_route_additions_now "Client Wizard"
    fi
    local -a dynamic_steps=()
    mapfile -t dynamic_steps < <(dynamic_operator_followups)
    action_output="$(recommended_quick_setup_action)"
    while IFS= read -r line; do
      case "$line" in
        label=*) priority_label="${line#label=}" ;;
      esac
    done <<EOF
$action_output
EOF
    show_next_steps "Client-scoped config update completed." \
      "Recommended next: ${priority_label:-Restart + Verify}." \
      "Restart + Verify to activate the new client default." \
      "Use Client Matrix to confirm the profile and match intent." \
      "Use the client drilldown to grab the exact setup hints again." \
      "${dynamic_steps[@]}"
    faigate_ui_pause
    offer_priority_followup_now
  else
    cmd_args+=(--dry-run-summary)
    run_and_pause_with_receipt "Client-scoped dry-run completed." 3 \
      "Write config when the client-specific routing change looks right." \
      "Check Client Matrix if you want to confirm the current profile posture." \
      "Run the matching client drilldown for copyable setup details." \
      env FAIGATE_PYTHON="$python_bin" FAIGATE_ENV_FILE="$env_file" \
      bash "${script_dir}/faigate-config-wizard" "${cmd_args[@]}"
  fi
}

status_menu() {
  while true; do
    show_status_overview
    echo ""
    render_summary_cards
    faigate_ui_tip "Use Service Status when you want the raw manager output and bound listener details."
    echo ""
    printf "    1)  Service Status   Detailed service/runtime status\n"
    printf "    2)  Health Check     Query /health\n"
    printf "    3)  Models           List exposed model ids\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-status" ;;
      2) run_and_pause bash "${script_dir}/faigate-health" ;;
      3) run_and_pause show_models ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

quick_setup_menu() {
  local provider_setup_label api_keys_label provider_probe_label full_config_label
  local validate_label restart_label scenarios_label quickstarts_label current_config_label
  local provider_catalog_label
  while true; do
    faigate_ui_header "fusionAIze Gate Quick Setup" "Fastest path from first keys to first healthy client"
    render_summary_cards
    render_quick_setup_guidance
    render_priority_next_step
    provider_setup_label="$(quick_setup_option_text 1 "Provider Setup")"
    api_keys_label="$(quick_setup_option_text 2 "API Keys")"
    provider_probe_label="$(quick_setup_option_text 3 "Provider Probe")"
    full_config_label="$(quick_setup_option_text 4 "Full Config Wizard")"
    validate_label="$(quick_setup_option_text 5 "Validate")"
    restart_label="$(quick_setup_option_text 6 "Restart + Verify")"
    scenarios_label="$(quick_setup_option_text 7 "Client Scenarios")"
    quickstarts_label="$(quick_setup_option_text 8 "Client Quickstarts")"
    current_config_label="$(quick_setup_option_text 9 "Current Config")"
    provider_catalog_label="$(quick_setup_option_text 10 "Provider Catalog")"
    echo ""
    printf "    1)  %-28s %s\n" "$provider_setup_label" "Add providers, local workers, or route mirrors"
    printf "    2)  %-28s %s\n" "$api_keys_label" "Set provider keys in the env file"
    printf "    3)  %-28s %s\n" "$provider_probe_label" "Check which configured providers really look ready"
    printf "    4)  %-28s %s\n" "$full_config_label" "Generate or update the main config"
    printf "    5)  %-28s %s\n" "$validate_label" "Run doctor checks against the current config"
    printf "    6)  %-28s %s\n" "$restart_label" "Restart the gateway and wait for /health"
    printf "    7)  %-28s %s\n" "$scenarios_label" "Apply client-specific templates like opencode/eco"
    printf "    8)  %-28s %s\n" "$quickstarts_label" "Show client-specific next steps"
    printf "    9)  %-28s %s\n" "$current_config_label" "Review the current config snapshot"
    printf "   10)  %-28s %s\n" "$provider_catalog_label" "Refresh mirrored model, pricing, and source metadata"
    printf "\n"
    printf "    r)  Recommended path             Open the highest-priority next step now\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_provider_setup_with_handoff ;;
      2) run_and_pause_with_priority_receipt "API keys updated." 3 \
        "Run Full Config Wizard when providers are still missing from config.yaml." \
        "Run Validate next to confirm provider env coverage." \
        "Restart + Verify only after config and env are both where you want them." \
        bash "${script_dir}/faigate-api-keys" ;;
      3) run_and_pause_with_priority_receipt "Provider probe completed." 3 \
        "Fix missing-key, model-unavailable, or quota states before routing real client traffic." \
        "Use Full Config Wizard next when the provider set is right but the client defaults still are not." \
        "Client Scenarios are the next layer once the providers themselves look ready." \
        bash "${script_dir}/faigate-provider-probe" ;;
      4) run_config_wizard ;;
      5) run_and_pause_with_priority_receipt "Validation completed." 3 \
        "Fix any missing env or endpoint warnings before restart work." \
        "Restart + Verify once the doctor output is clean enough." \
        "Open Client Quickstarts when the gateway looks healthy." \
        bash "${script_dir}/faigate-doctor" ;;
      6) run_and_pause_with_priority_receipt "Gateway restart completed." 3 \
        "Run Health Check if you want the live runtime summary again." \
        "Open Status when you need service-manager and listener details." \
        "Open Client Quickstarts to connect the first real client." \
        bash "${script_dir}/faigate-restart" ;;
      7) run_and_pause_with_priority_receipt "Client scenarios loaded." 3 \
        "Pick one scenario when you want opencode, n8n, or CLI traffic to get a deliberate default mode." \
        "Restart + Verify after writing a scenario so the live runtime picks it up." \
        "Return to Client Quickstarts when you want copyable connection details for one client." \
        bash "${script_dir}/faigate-client-scenarios" ;;
      8) run_and_pause_with_priority_receipt "Client quickstarts loaded." 3 \
        "Open one client drilldown when you want copyable details for exactly one tool." \
        "Use a client-scoped wizard when one client needs a tuned routing default." \
        "Return to Quick Setup when you want the shortest path again." \
        bash "${script_dir}/faigate-client-integrations" --recommended ;;
      9) run_and_pause bash "${script_dir}/faigate-config-overview" ;;
      10) run_and_pause_with_priority_receipt "Provider catalog refreshed." 3 \
        "Review refresh errors before trusting stale provider docs or pricing assumptions." \
        "Provider Probe is the next step when one route still does not look request-ready after the catalog refresh." \
        "Return to Quick Setup when you want the next recommended operator path again." \
        bash "${script_dir}/faigate-provider-catalog" --refresh ;;
      r|R) run_recommended_quick_setup_action ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

configure_menu() {
  while true; do
    faigate_ui_header "fusionAIze Gate Configure" "Config, providers, and local gateway settings"
    render_summary_cards
    faigate_ui_tip "Use Provider Setup when you need to add sources first. Use Guided Setup for purpose- and client-aware defaults after the sources exist."
    echo ""
    printf "    1)  Current Config   Snapshot of bind settings, providers, modes, and profiles\n"
    printf "    2)  Provider Setup   Add known providers, custom endpoints, or local workers\n"
    printf "    3)  Guided Setup     Wizard-led provider and client-profile flows\n"
    printf "    4)  Direct Settings  API keys, HTTP settings, and routing defaults\n"
    printf "\n"
    printf "    c)  Cancel\n"
    printf "    q)  Quit\n\n"
    printf "  ▸ Choice: "
    read -r choice
    case "$choice" in
      1) run_and_pause bash "${script_dir}/faigate-config-overview" ;;
      2) run_and_pause bash "${script_dir}/faigate-provider-setup" ;;
      3) configure_guided_menu ;;
      4) configure_direct_menu ;;
      c|C|"") return 0 ;;
      q|Q) exit 0 ;;
      *) faigate_ui_warn "Invalid choice."; faigate_ui_pause ;;
    esac
  done
}

