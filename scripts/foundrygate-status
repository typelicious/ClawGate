#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/foundrygate-service-lib.sh"

case "$(foundrygate_platform)" in
  Darwin)
    foundrygate_launchctl_status
    echo
    lsof -nP -iTCP:8090 -sTCP:LISTEN || true
    ;;
  *)
    sudo systemctl status foundrygate.service --no-pager -l
    echo
    sudo ss -ltnp | grep -E "127\\.0\\.0\\.1:8090\\b" || true
    ;;
esac
