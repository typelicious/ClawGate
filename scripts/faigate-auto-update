#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-auto-update [--json|--apply]

Inspect or apply the helper-driven auto-update path against /api/update.

Options:
  --json   Print the raw JSON payload
  --apply  Run the configured apply command when the current status is eligible
EOF
}

api_url="${FAIGATE_UPDATE_API_URL:-$(faigate_update_url)?force=true}"
mode="${1:-}"
python_bin="${FAIGATE_PYTHON:-python3}"

case "$mode" in
  --help|-h)
    usage
    exit 0
    ;;
  ""|--json|--apply)
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

operator_action="auto-update-check"
if [ "$mode" = "--apply" ]; then
  operator_action="auto-update-apply"
fi

payload="$(curl -fsS \
  -H 'X-faigate-Client: operator' \
  -H "X-faigate-Operator-Action: ${operator_action}" \
  "$api_url")"

if [ "$mode" = "--json" ]; then
  printf '%s\n' "$payload"
  exit 0
fi

export FAIGATE_UPDATE_PAYLOAD="$payload"

parsed_output="$("$python_bin" - <<'PY'
import json
import os

payload = json.loads(os.environ["FAIGATE_UPDATE_PAYLOAD"])
auto = payload.get("auto_update") or {}

current = payload.get("current_version") or "unknown"
latest = payload.get("latest_version") or current
update_type = payload.get("update_type") or "unknown"
recommended = payload.get("recommended_action") or ""
enabled = bool(auto.get("enabled"))
eligible = bool(auto.get("eligible"))
blocked = auto.get("blocked_reason") or ""
apply_command = auto.get("apply_command") or "faigate-update"

for value in (
    current,
    latest,
    payload.get("status") or "unknown",
    update_type,
    recommended,
    "true" if enabled else "false",
    "true" if eligible else "false",
    blocked,
    apply_command,
    "true" if bool((auto.get("verification") or {}).get("enabled")) else "false",
    ((auto.get("verification") or {}).get("command") or "faigate-health"),
    str((auto.get("verification") or {}).get("timeout_seconds") or 30),
    ((auto.get("verification") or {}).get("rollback_command") or ""),
):
    print(value)
PY
)"

parsed=()
while IFS= read -r line; do
  parsed+=("$line")
done <<EOF
$parsed_output
EOF
current="${parsed[0]-}"
latest="${parsed[1]-}"
status="${parsed[2]-}"
update_type="${parsed[3]-}"
recommended_action="${parsed[4]-}"
auto_enabled="${parsed[5]-}"
auto_eligible="${parsed[6]-}"
auto_blocked_reason="${parsed[7]-}"
apply_command="${parsed[8]-}"
verify_enabled="${parsed[9]-}"
verify_command="${parsed[10]-}"
verify_timeout="${parsed[11]-}"
rollback_command="${parsed[12]-}"

if [ "$mode" = "--apply" ]; then
  if [ "$auto_enabled" != "true" ]; then
    echo "auto-update is disabled" >&2
    exit 1
  fi
  if [ "$auto_eligible" != "true" ]; then
    echo "auto-update not eligible: ${auto_blocked_reason:-blocked}" >&2
    exit 1
  fi

  echo "Applying ${update_type} update to ${latest} via: ${apply_command}"
  /bin/sh -lc "$apply_command"

  if [ "$verify_enabled" = "true" ]; then
    echo "Running post-update verification via: ${verify_command}"
    export FAIGATE_VERIFY_COMMAND="$verify_command"
    export FAIGATE_VERIFY_TIMEOUT="$verify_timeout"
    if ! "$python_bin" - <<'PY'
import os
import subprocess
import sys

command = os.environ["FAIGATE_VERIFY_COMMAND"]
timeout = int(os.environ["FAIGATE_VERIFY_TIMEOUT"])
completed = subprocess.run(command, shell=True, timeout=timeout)
sys.exit(completed.returncode)
PY
    then
      echo "post-update verification failed" >&2
      if [ -n "$rollback_command" ]; then
        echo "rollback suggested: ${rollback_command}" >&2
      fi
      exit 1
    fi
  fi
  exit 0
fi

printf 'Current: %s\nLatest: %s\nStatus: %s\nUpdate type: %s\nAction: %s\n' \
  "$current" "$latest" "$status" "$update_type" "$recommended_action"

if [ "$auto_enabled" = "true" ]; then
  if [ "$auto_eligible" = "true" ]; then
    printf 'Auto-update: eligible via %s\n' "$apply_command"
  else
    printf 'Auto-update: blocked (%s)\n' "${auto_blocked_reason:-blocked}"
  fi
  if [ "$verify_enabled" = "true" ]; then
    printf 'Post-update verification: %s (timeout %ss)\n' "$verify_command" "$verify_timeout"
    if [ -n "$rollback_command" ]; then
      printf 'Rollback hint: %s\n' "$rollback_command"
    fi
  fi
else
  printf 'Auto-update: disabled\n'
fi
