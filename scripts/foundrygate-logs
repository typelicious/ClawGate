#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/foundrygate-service-lib.sh"

case "$(foundrygate_platform)" in
  Darwin)
    mkdir -p "$(foundrygate_mac_logs_dir)"
    touch "$(foundrygate_mac_logs_dir)/stdout.log" "$(foundrygate_mac_logs_dir)/stderr.log"
    tail -f "$(foundrygate_mac_logs_dir)/stdout.log" "$(foundrygate_mac_logs_dir)/stderr.log"
    ;;
  *)
    sudo journalctl -u foundrygate.service -f -o cat
    ;;
esac
