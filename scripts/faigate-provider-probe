#!/usr/bin/env bash
set -euo pipefail

source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/faigate-service-lib.sh"

config_file="$(faigate_config_file)"
env_file="$(faigate_env_file)"
python_bin="$(faigate_python_bin)"
mode="text"
live_probe="0"
refresh_catalog="0"
timeout_seconds="2.0"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-provider-probe [--json|--text] [--live] [--refresh-catalog] [--timeout SECONDS]

Probe configured provider sources against the current config, env file, and
local /health payload when available. Use --live to run shallow transport-aware
request probes directly against the configured providers. Use --refresh-catalog
to refresh provider source snapshots before rendering the report.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      mode="json"
      shift
      ;;
    --text)
      mode="text"
      shift
      ;;
    --live)
      live_probe="1"
      shift
      ;;
    --refresh-catalog)
      refresh_catalog="1"
      shift
      ;;
    --timeout)
      timeout_seconds="${2:-}"
      if [[ -z "$timeout_seconds" ]]; then
        usage >&2
        exit 2
      fi
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done

health_payload=""
if payload="$(curl -fsS -m 2 "$(faigate_health_url)" 2>/dev/null)"; then
  health_payload="$payload"
fi

FAIGATE_PROVIDER_PROBE_CONFIG="$config_file" \
FAIGATE_PROVIDER_PROBE_ENV="$env_file" \
FAIGATE_PROVIDER_PROBE_MODE="$mode" \
FAIGATE_PROVIDER_PROBE_HEALTH="$health_payload" \
FAIGATE_PROVIDER_PROBE_LIVE="$live_probe" \
FAIGATE_PROVIDER_PROBE_REFRESH_CATALOG="$refresh_catalog" \
FAIGATE_PROVIDER_PROBE_TIMEOUT="$timeout_seconds" \
"$python_bin" - <<'PY'
import json
import os

from faigate.config import load_config
from faigate.provider_availability import (
    record_availability_from_health,
    refresh_local_model_availability,
)
from faigate.provider_catalog_refresh import (
    ProviderCatalogRefresher,
    build_catalog_alert_summary,
    build_catalog_summary,
    render_catalog_summary_text,
)
from faigate.provider_catalog_store import ProviderCatalogStore
from faigate.wizard import build_provider_probe_report, render_provider_probe_text

health_raw = os.environ.get("FAIGATE_PROVIDER_PROBE_HEALTH", "").strip()
health_payload = json.loads(health_raw) if health_raw else None
config = load_config(os.environ["FAIGATE_PROVIDER_PROBE_CONFIG"])
store = None
catalog_summary = {}
catalog_alerts = []
catalog_alert_summary = {"status": "clear", "fix_now": 0, "review_now": 0, "inspect": 0}
catalog_store_error = ""
try:
    store = ProviderCatalogStore(str(config.metrics.get("db_path") or ""))
    store.init()
except Exception as exc:
    catalog_store_error = str(exc)

if store is not None and os.environ.get("FAIGATE_PROVIDER_PROBE_REFRESH_CATALOG") == "1":
    refresher = ProviderCatalogRefresher(store)
    refresher.refresh(
        provider_ids=list(config.provider_source_refresh.get("providers") or []),
        timeout_seconds=float(os.environ.get("FAIGATE_PROVIDER_PROBE_TIMEOUT") or "2.0"),
    )
if store is not None:
    record_availability_from_health(
        store,
        config_path=os.environ["FAIGATE_PROVIDER_PROBE_CONFIG"],
        health_payload=health_payload,
    )
    if os.environ.get("FAIGATE_PROVIDER_PROBE_REFRESH_CATALOG") == "1":
        refresh_local_model_availability(
            store,
            config_path=os.environ["FAIGATE_PROVIDER_PROBE_CONFIG"],
            provider_ids=list(config.provider_source_refresh.get("providers") or []),
            timeout_seconds=float(os.environ.get("FAIGATE_PROVIDER_PROBE_TIMEOUT") or "2.0"),
        )
    catalog_summary = build_catalog_summary(
        store,
        provider_ids=list(config.provider_source_refresh.get("providers") or []),
    )
    catalog_alerts = list(catalog_summary.get("alerts") or [])
    catalog_alert_summary = build_catalog_alert_summary(catalog_alerts)
report = build_provider_probe_report(
    config_path=os.environ["FAIGATE_PROVIDER_PROBE_CONFIG"],
    env_file=os.environ["FAIGATE_PROVIDER_PROBE_ENV"],
    health_payload=health_payload,
    live_probe=os.environ.get("FAIGATE_PROVIDER_PROBE_LIVE") == "1",
    timeout_seconds=float(os.environ.get("FAIGATE_PROVIDER_PROBE_TIMEOUT") or "2.0"),
)

if os.environ["FAIGATE_PROVIDER_PROBE_MODE"] == "json":
    payload = {
        "catalog_summary": catalog_summary,
        "catalog_alerts": catalog_alerts,
        "catalog_alert_summary": catalog_alert_summary,
        "probe_report": report,
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
else:
    print(render_catalog_summary_text(catalog_summary, heading="Provider source catalog"), end="")
    if catalog_store_error:
        print(f"[warn] provider source catalog unavailable: {catalog_store_error}")
    if catalog_alerts:
        print("Catalog alert actions")
        for alert in catalog_alerts[:3]:
            print(
                f"- {alert.get('provider_id')}: {alert.get('action') or 'inspect'} | "
                f"{alert.get('headline')}"
            )
            if alert.get("suggestion"):
                print(f"  next: {alert['suggestion']}")
        print(
            "Action summary: "
            + f"fix-now={int(catalog_alert_summary.get('fix_now') or 0)} | "
            + f"review-now={int(catalog_alert_summary.get('review_now') or 0)} | "
            + f"inspect={int(catalog_alert_summary.get('inspect') or 0)}"
        )
        print("")
    print(render_provider_probe_text(report), end="")

if store is not None:
    store.close()
PY
