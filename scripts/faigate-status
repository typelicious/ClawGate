#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

source "${script_dir}/faigate-service-lib.sh"
source "${script_dir}/faigate-ui-lib.sh"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/faigate-status [--summary|--raw]

Show the current fusionAIze Gate service manager, config paths, bind target,
health state, and service status.
EOF
}

mode="summary"
case "${1:-}" in
  --help|-h)
    usage
    exit 0
    ;;
  --raw)
    mode="raw"
    ;;
  --summary|"")
    mode="summary"
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

show_raw_status() {
  local port
  port="$(faigate_port)"
  case "$(faigate_platform)" in
    Darwin)
      if faigate_is_homebrew_runtime; then
        local brew_row
        brew_row="$("$(faigate_brew_bin)" services list 2>/dev/null | awk '$1=="faigate" {print $0; exit}')"
        if [ -n "$brew_row" ]; then
          printf '%s\n' "$brew_row"
        else
          echo "brew services does not list faigate."
        fi
        echo
        faigate_launchctl_status 2>/dev/null || echo "launchd details unavailable for $(faigate_service_target)."
      else
        faigate_launchctl_status 2>/dev/null || echo "launchd details unavailable for $(faigate_service_target)."
      fi
      echo
      lsof -nP -iTCP:"${port}" -sTCP:LISTEN || true
      ;;
    *)
      sudo systemctl status faigate.service --no-pager -l
      echo
      sudo ss -ltnp | grep -E ":${port}\\b" || true
      ;;
  esac
}

if [ "$mode" = "raw" ]; then
  show_raw_status
  exit 0
fi

state="$(faigate_service_state)"
enabled_state="$(faigate_service_enabled_state)"
if faigate_is_healthy; then
  health_state="healthy"
else
  health_state="unreachable"
fi

manager_mismatch_warning=""
case "$state" in
  active|started|running|configured)
    ;;
  *)
    if [ "$health_state" = "healthy" ]; then
      manager_mismatch_warning="Health responds even though the configured service manager reports '${state}'. Another local process may still own $(faigate_host):$(faigate_port)."
    fi
    ;;
esac

faigate_ui_header "fusionAIze Gate Service Status" "Control-plane overview with runtime context"
printf "  %-18s %s\n" "Manager" "$(faigate_service_manager)"
printf "  %-18s %s\n" "Target" "$(faigate_service_target)"
printf "  %-18s %s\n" "State" "$state"
printf "  %-18s %s\n" "Enabled" "$enabled_state"
printf "  %-18s %s\n" "Config" "$(faigate_config_file)"
printf "  %-18s %s\n" "Env" "$(faigate_env_file)"
printf "  %-18s %s\n" "Database" "$(faigate_db_path)"
printf "  %-18s %s\n" "Bind" "$(faigate_host):$(faigate_port)"
printf "  %-18s %s\n" "Health URL" "$(faigate_health_url)"
printf "  %-18s %s\n" "Models URL" "$(faigate_models_url)"
printf "  %-18s %s\n" "Stdout logs" "$(faigate_logs_stdout_path)"
printf "  %-18s %s\n" "Stderr logs" "$(faigate_logs_stderr_path)"
printf "  %-18s %s\n" "Health" "$health_state"

if [ -n "$manager_mismatch_warning" ]; then
  echo ""
  faigate_ui_warn "$manager_mismatch_warning"
fi

echo ""
printf "  %bRaw status%b\n" "$FAIGATE_UI_BOLD" "$FAIGATE_UI_RESET"
show_raw_status
