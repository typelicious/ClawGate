#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
env_file="${1:-$repo_root/.env}"
state_dir="${FAIGATE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/faigate}"
db_path="${FAIGATE_DB_PATH:-$state_dir/faigate.db}"

mkdir -p "$state_dir"

if [ ! -f "$env_file" ]; then
  cp "$repo_root/.env.example" "$env_file"
  created_env=yes
else
  created_env=no
fi

if ! grep -Eq '^[[:space:]]*FAIGATE_DB_PATH=' "$env_file"; then
  printf '\nFAIGATE_DB_PATH=%s\n' "$db_path" >> "$env_file"
  added_db_path=yes
else
  added_db_path=no
fi

cat <<EOF
fusionAIze Gate bootstrap complete.

- env file: $env_file
- state dir: $state_dir
- db path : $db_path
- .env created: $created_env
- FAIGATE_DB_PATH added: $added_db_path

Next steps:
1. Edit $env_file and set at least one provider API key.
2. Run ./scripts/faigate-config-wizard --purpose general > config.yaml to generate a first config.
3. Run ./scripts/faigate-doctor to verify the local setup.
4. Start fusionAIze Gate with python -m faigate or use the systemd helper flow.
EOF
